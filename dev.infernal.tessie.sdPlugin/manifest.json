      "Tooltip": "View your vehicle's location.",
      "PropertyInspectorPath": "ui/location.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/counter/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Tire Pressure",
      "UUID": "dev.infernal.tessie.tire-pressure",
      "Icon": "imgs/actions/counter/icon",
      "Tooltip": "View your vehicle's tire pressure.",
      "PropertyInspectorPath": "ui/tire-pressure.html",
      "Controllers": ["Keypad"],
