{
  "Name": "Tessie (Unofficial)",
  "Version": "0.1.0.0",
  "Author": "infernal.dev",
  "Actions": [
    {
      "Name": "Toggle Climate",
      "UUID": "dev.infernal.tessie.climate",
      "Icon": "imgs/actions/counter/icon",
      "Tooltip": "Toggle climate in your vehicle.",
      "PropertyInspectorPath": "ui/climate.html",
      "Controllers": ["Keypad"],
      "DisableAutomaticStates": true,
      "States": [
        {
          "Image": "imgs/actions/counter/key",
          "TitleAlignment": "middle",
          "Name": "Start Climate",
          "Title": "Start\nClimate"
        },
        {
          "Image": "imgs/actions/counter/key",
          "TitleAlignment": "middle",
          "Name": "Stop Climate",
          "Title": "Stop\nClimate"
        }
      ]
    },
    {
      "Name": "Battery Status",
      "UUID": "dev.infernal.tessie.battery",
      "Icon": "imgs/actions/counter/icon",
      "Tooltip": "View your vehicle's battery status.",
      "PropertyInspectorPath": "ui/battery.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/counter/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Battery Health",
      "UUID": "dev.infernal.tessie.battery-health-measurements",
      "Icon": "imgs/actions/counter/icon",
      "Tooltip": "View your vehicle's battery health.",
      "PropertyInspectorPath": "ui/battery-health-measurements.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/counter/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Location",
      "UUID": "dev.infernal.tessie.location",
